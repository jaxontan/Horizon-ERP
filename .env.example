# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ACCESS_TOKEN=your_supabase_access_token
SUPABASE_PUBLISHABLE_SECRET_KET=your_supabase_publishable_secret_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Brevo SMTP Email Configuration
# Login is the email-shaped identifier Brevo shows on the SMTP Settings panel.
BREVO_SMTP_LOGIN=your_brevo_smtp_login@smtp-brevo.com

# SMTP key from Brevo → Settings → SMTP & API → SMTP tab.
BREVO_SMTP_KEY=your_brevo_smtp_key

# Friendly sender name + email. Must be a sender verified in Brevo dashboard.
BREVO_FROM_B2C="Espressgo <your_email@domain.com>"
BREVO_FROM_B2B="Espressgo <your_email@domain.com>"

# Reply-To address (replies land in this inbox regardless of From).
BREVO_REPLY_TO=your_email@domain.com

# Email Outreach Settings
OUTREACH_SANDBOX_MODE=false
OUTREACH_MAX_RECIPIENTS_PER_RUN=50
OUTREACH_DELAY_BETWEEN_MS=1500

# Cookie Configuration (Optional)
# SESSION_COOKIE_SECURE=false

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
MODEL=meta-llama/llama-3.3-70b-instruct
